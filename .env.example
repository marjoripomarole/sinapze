# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — overrides defaults
MEDSTUDY_LLM_MODEL=claude-sonnet-4-6
MEDSTUDY_LLM_TEMPERATURE=0.3
MEDSTUDY_DATA_DIR=./.medstudy
MEDSTUDY_DEFAULT_LANGUAGE=auto  # 'auto' | 'pt-BR' | 'en'

# For verifier pass — costs ~30% more tokens but drops hallucinations
MEDSTUDY_VERIFY_CARDS=true
